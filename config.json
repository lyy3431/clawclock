{
  "display_mode": "analog",
  "stopwatch": {
    "auto_save_laps": false,
    "show_milliseconds": true
  },
  "theme": {
    "colors": {
      "accent": "#0f3460",
      "background": "#1a1a2e",
      "face": "#16213e",
      "hand": "#e94560",
      "segment_off": "#331111",
      "segment_on": "#ff3333",
      "text": "#ffffff"
    },
    "name": "dark"
  },
  "timezone": "Asia/Shanghai",
  "window": {
    "always_on_top": false,
    "fullscreen": false,
    "height": 500,
    "resizable": false,
    "width": 600,
    "x": 0,
    "y": 0
  }
}
